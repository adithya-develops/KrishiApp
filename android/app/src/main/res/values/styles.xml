<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Launch theme shown immediately when app starts -->
    <style name="LaunchTheme" parent="Theme.AppCompat.DayNight.NoActionBar">

        <!-- Background -->
        <item name="android:windowBackground">@drawable/launch_background</item>

        <!-- Android 12+ splash background -->
        <item name="android:windowSplashScreenBackground">@drawable/launch_background</item>

        <!-- Remove launcher icon -->
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>

    </style>

    <!-- Normal theme -->
    <style name="NormalTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>

</resources>
